---
import Container from '../Container.astro';

type Cell = string | boolean;

interface Row {
  label: string;
  values: Cell[];
}

const plans = [
  { name: 'Free', price: '$0 / mo', featured: false },
  { name: 'Pro', price: '$20 / seat / mo', featured: true },
  { name: 'Scale', price: '$250 / mo', featured: false },
];

const groups: { name: string; rows: Row[] }[] = [
  {
    name: 'Usage',
    rows: [
      { label: 'Requests / month', values: ['100k', '10M', 'Unlimited'] },
      { label: 'Edge regions', values: ['3', '28', '28'] },
      { label: 'Team seats', values: ['1', 'Per seat', 'Unlimited'] },
    ],
  },
  {
    name: 'Platform',
    rows: [
      { label: 'Edge caching (SWR)', values: [true, true, true] },
      { label: 'Custom domains', values: ['1', '10', 'Unlimited'] },
      { label: 'Preview deploys', values: [false, true, true] },
      { label: 'SAML SSO', values: [false, false, true] },
    ],
  },
  {
    name: 'Observability',
    rows: [
      { label: 'Log retention', values: ['24 h', '30 d', '90 d'] },
      { label: 'Request-level tracing', values: [false, true, true] },
      { label: 'OpenTelemetry export', values: [false, false, true] },
    ],
  },
  {
    name: 'Support',
    rows: [
      { label: 'Email support', values: [false, true, true] },
      { label: 'Dedicated Slack channel', values: [false, false, true] },
      { label: 'Uptime SLA', values: [false, false, '99.99%'] },
    ],
  },
];
---

<section class="border-t border-line py-20 sm:py-28">
  <Container>
    <div class="max-w-2xl">
      <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Compare plans</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
        Every plan, line by line
      </h2>
      <p class="mt-4 max-w-xl leading-relaxed text-fg-2">
        The complete matrix — no hidden tiers, no “call us” for the basics. Switch plans whenever
        you like; your deployments stay exactly where they are.
      </p>
    </div>

    <!-- Desktop table -->
    <div class="mt-12 hidden md:block">
      <table class="w-full table-fixed border-collapse text-left">
        <caption class="sr-only">Feature comparison of the Free, Pro, and Scale plans</caption>
        <colgroup>
          <col class="w-[34%]" />
          <col />
          <col class="bg-brand/5" />
          <col />
        </colgroup>
        <thead>
          <tr class="border-b border-line">
            <td></td>
            {
              plans.map((plan) => (
                <th scope="col" class="px-3 py-5 text-center">
                  <div class="text-sm font-semibold text-fg">{plan.name}</div>
                  <div class="mt-1 font-mono text-xs font-normal text-fg-2">{plan.price}</div>
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            groups.map((group) => (
              <Fragment>
                <tr class="border-b border-line">
                  <th
                    colspan="4"
                    scope="colgroup"
                    class="pb-3 pt-8 text-left font-mono text-[12px] font-normal uppercase tracking-widest text-fg-3"
                  >
                    {group.name}
                  </th>
                </tr>
                {group.rows.map((row) => (
                  <tr class="border-b border-line">
                    <th
                      scope="row"
                      class="py-3.5 pr-4 text-left font-mono text-[13px] font-normal text-fg-2"
                    >
                      {row.label}
                    </th>
                    {row.values.map((value) => (
                      <td class="px-3 py-3.5 text-center text-sm text-fg-2">
                        {typeof value === 'string' ? (
                          value
                        ) : value ? (
                          <Fragment>
                            <svg
                              class="mx-auto text-accent"
                              width="16"
                              height="16"
                              viewBox="0 0 16 16"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M2.75 8.5 6 11.75 13.25 4.5" />
                            </svg>
                            <span class="sr-only">Included</span>
                          </Fragment>
                        ) : (
                          <Fragment>
                            <span aria-hidden="true" class="text-fg-3">
                              —
                            </span>
                            <span class="sr-only">Not included</span>
                          </Fragment>
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
              </Fragment>
            ))
          }
        </tbody>
      </table>
    </div>

    <!-- Mobile: one stacked card per plan -->
    <div class="mt-12 space-y-4 md:hidden">
      {
        plans.map((plan, planIndex) => (
          <div
            class:list={[
              'overflow-hidden rounded-xl border bg-panel',
              plan.featured ? 'border-brand/50' : 'border-line',
            ]}
          >
            <div class="flex items-baseline justify-between border-b border-line px-5 py-4">
              <h3 class="text-sm font-semibold text-fg">{plan.name}</h3>
              <span class="font-mono text-xs text-fg-2">{plan.price}</span>
            </div>
            <div class="px-5 pb-5">
              {groups.map((group) => (
                <div class="pt-5">
                  <h4 class="font-mono text-[11px] uppercase tracking-widest text-fg-3">
                    {group.name}
                  </h4>
                  <dl class="mt-2 divide-y divide-line">
                    {group.rows.map((row) => (
                      <div class="flex items-center justify-between gap-4 py-2.5">
                        <dt class="font-mono text-[13px] text-fg-2">{row.label}</dt>
                        <dd class="text-right text-sm text-fg">
                          {typeof row.values[planIndex] === 'string' ? (
                            row.values[planIndex]
                          ) : row.values[planIndex] ? (
                            <Fragment>
                              <svg
                                class="text-accent"
                                width="16"
                                height="16"
                                viewBox="0 0 16 16"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"
                              >
                                <path d="M2.75 8.5 6 11.75 13.25 4.5" />
                              </svg>
                              <span class="sr-only">Included</span>
                            </Fragment>
                          ) : (
                            <Fragment>
                              <span aria-hidden="true" class="text-fg-3">
                                —
                              </span>
                              <span class="sr-only">Not included</span>
                            </Fragment>
                          )}
                        </dd>
                      </div>
                    ))}
                  </dl>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
