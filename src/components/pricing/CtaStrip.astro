---
import Button from '../Button.astro';
import Container from '../Container.astro';
import Glow from '../Glow.astro';
---

<section class="relative overflow-hidden border-t border-line">
  <Glow class="left-1/2 top-1/2 h-[260px] w-[640px] -translate-x-1/2 -translate-y-1/2 opacity-60" />
  <Container class="relative py-16 sm:py-20">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
          Start with 100k free requests
        </h2>
        <p class="mt-2 leading-relaxed text-fg-2">
          Deploy your first endpoint in under a minute. No credit card required.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <Button href="#">Start building free</Button>
        <Button href="/docs/getting-started/quickstart/" variant="secondary">Read the docs</Button>
      </div>
    </div>
  </Container>
</section>
