---
import Button from '../Button.astro';

interface Tier {
  name: string;
  price: string;
  suffix: string;
  description: string;
  cta: { label: string; href: string; variant: 'primary' | 'secondary' };
  featured?: boolean;
  intro?: string;
  features: string[];
}

const tiers: Tier[] = [
  {
    name: 'Free',
    price: '$0',
    suffix: '/ mo',
    description: 'Everything you need to ship a side project on real infrastructure.',
    cta: { label: 'Start for free', href: '#', variant: 'secondary' },
    features: [
      '100k requests per month',
      '3 edge regions',
      'Edge caching with SWR',
      'CLI deploys and the @vega/sdk',
      '24-hour log retention',
      'Community support',
    ],
  },
  {
    name: 'Pro',
    price: '$20',
    suffix: '/ seat / mo',
    description: 'For teams running production APIs that other people depend on.',
    cta: { label: 'Get started', href: '#', variant: 'primary' },
    featured: true,
    intro: 'Everything in Free, plus',
    features: [
      '10M requests per month',
      'All 28 edge regions',
      'Request-level tracing',
      'Preview deploys for every branch',
      '30-day log retention',
      'Email support, next business day',
    ],
  },
  {
    name: 'Scale',
    price: '$250',
    suffix: '/ mo',
    description: 'For companies that need guarantees — uptime, security, and a human on call.',
    cta: { label: 'Contact sales', href: '#', variant: 'secondary' },
    intro: 'Everything in Pro, plus',
    features: [
      'Unlimited requests',
      'Unlimited team seats',
      'SAML SSO',
      '99.99% uptime SLA',
      '90-day log retention',
      'Dedicated Slack channel',
    ],
  },
];
---

<div class="grid gap-6 md:grid-cols-3 md:gap-5 lg:gap-6">
  {
    tiers.map((tier) => (
      <div
        class:list={[
          'relative flex flex-col rounded-xl border p-6',
          tier.featured
            ? 'border-brand/50 bg-panel shadow-[0_0_48px_-12px_rgb(139_92_246/0.45)]'
            : 'border-line bg-panel transition-colors hover:border-line-2',
        ]}
      >
        {tier.featured && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-brand/50 bg-ink px-3 py-1 font-mono text-[11px] uppercase tracking-widest text-brand-bright">
            Most popular
          </span>
        )}

        <h2 class="text-sm font-semibold text-fg">{tier.name}</h2>

        <p class="mt-4 flex items-baseline gap-2">
          <span class="text-4xl font-semibold tracking-tight text-fg">{tier.price}</span>
          <span class="font-mono text-[13px] text-fg-2">{tier.suffix}</span>
        </p>

        <p class="mt-3 text-sm leading-relaxed text-fg-2">{tier.description}</p>

        <Button href={tier.cta.href} variant={tier.cta.variant} class="mt-6 w-full">
          {tier.cta.label}
        </Button>

        <div class="mt-6 border-t border-line pt-6">
          {tier.intro && <p class="text-[13px] text-fg-3">{tier.intro}</p>}
          <ul role="list" class:list={['space-y-3', tier.intro && 'mt-4']}>
            {tier.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-fg-2">
                <svg
                  class="mt-0.5 shrink-0 text-accent"
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M2.75 8.5 6 11.75 13.25 4.5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))
  }
</div>
