---
/**
 * Pulsar override of Starlight's `Header` component.
 *
 * Renders the same internals as the Starlight 0.40 default (SiteTitle,
 * Search, SocialIcons, ThemeSelect, LanguageSelect — see
 * https://starlight.astro.build/reference/overrides/#header) and adds the
 * marketing-site nav links plus the "Get started" CTA, so docs pages keep
 * the same shell as the rest of the site.
 *
 * Sub-components are imported from `@astrojs/starlight/components` — the
 * documented public path for reusing default components inside overrides
 * (https://starlight.astro.build/guides/overriding-components/).
 *
 * The default header gates `<Search />` behind `config.pagefind`; this
 * project keeps Pagefind enabled (Starlight's default), so Search renders
 * unconditionally here.
 */
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';

// Mirrors src/components/Nav.astro. Every Starlight page lives under
// /docs/, so "Docs" is always the current section here.
const links = [
  { label: 'Docs', href: '/docs/getting-started/quickstart/', current: true },
  { label: 'Pricing', href: '/pricing/', current: false },
  { label: 'Changelog', href: '/changelog/', current: false },
  { label: 'Blog', href: '/blog/', current: false },
];
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex print:hidden">
    <Search />
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <nav class="marketing-nav sl-hidden lg:sl-flex" aria-label="Vega site">
      {
        links.map(({ label, href, current }) => (
          <a href={href} aria-current={current ? 'page' : undefined}>
            {label}
          </a>
        ))
      }
    </nav>
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
    <a class="cta" href="/pricing/">Get started</a>
  </div>
</div>

<style>
  /* Layout rules below are copied verbatim from Starlight 0.40's default
	   Header.astro so search sizing, title clipping and the responsive grid
	   behave exactly as stock. Pulsar additions are marked at the end. */
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      /* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
      overflow: clip;
      /* Avoid clipping focus ring around link inside title wrapper. */
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }
    .social-icons::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        display: grid;
        grid-template-columns:
          /* 1 (site title): runs up until the main content column’s left edge or the width of the title, whichever is the largest  */
          minmax(
            calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
            auto
          )
          /* 2 (search box): all free space that is available. */
          1fr
          /* 3 (right items): use the space that these need. */
          auto;
        align-content: center;
      }
    }

    /* ── Pulsar additions ──────────────────────────────────────
		   Marketing nav links + Get started CTA, matching
		   src/components/Nav.astro. Tokens come from the --pulsar-*
		   custom properties declared in src/styles/starlight.css,
		   with Starlight palette variables as fallbacks. */

    .marketing-nav {
      gap: 1.75rem;
      align-items: center;
    }

    .marketing-nav a {
      font-size: 0.875rem;
      line-height: 1;
      text-decoration: none;
      color: var(--pulsar-fg-2, var(--sl-color-gray-2));
      transition: color 150ms;
    }

    .marketing-nav a:hover {
      color: var(--pulsar-fg, var(--sl-color-white));
    }

    .marketing-nav a[aria-current='page'] {
      color: var(--pulsar-fg, var(--sl-color-white));
    }

    .marketing-nav a:focus-visible {
      outline: 2px solid var(--pulsar-brand, var(--sl-color-accent));
      outline-offset: 2px;
    }

    /* Mirrors Button.astro variant="primary" size="sm". */
    .cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 2rem;
      padding-inline: 0.75rem;
      border-radius: 0.5rem;
      font-size: 0.875rem;
      font-weight: 500;
      white-space: nowrap;
      text-decoration: none;
      color: var(--pulsar-ink, var(--sl-color-black));
      background: linear-gradient(
        to right,
        var(--pulsar-brand, var(--sl-color-accent)),
        var(--pulsar-accent, var(--sl-color-accent-high))
      );
      box-shadow:
        0 0 24px color-mix(in srgb, var(--pulsar-brand, var(--sl-color-accent)) 35%, transparent),
        0 0 64px
          color-mix(in srgb, var(--pulsar-accent, var(--sl-color-accent-high)) 12%, transparent);
      transition: filter 200ms;
    }

    .cta:hover {
      filter: brightness(1.1);
    }

    .cta:active {
      filter: brightness(0.95);
    }

    .cta:focus-visible {
      outline: 2px solid var(--pulsar-brand, var(--sl-color-accent));
      outline-offset: 2px;
    }
  }
</style>
