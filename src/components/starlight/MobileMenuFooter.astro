---
/**
 * Pulsar override of Starlight's `MobileMenuFooter` component.
 *
 * The marketing nav links in the header are hidden on small viewports, so
 * this adds them to the bottom of the mobile docs drawer instead, then
 * renders Starlight's default footer (social icons row) untouched —
 * the documented "reuse the default component" override pattern
 * (https://starlight.astro.build/guides/overriding-components/).
 */
import Default from '@astrojs/starlight/components/MobileMenuFooter.astro';

const links = [
  { label: 'Docs', href: '/docs/getting-started/quickstart/', current: true },
  { label: 'Pricing', href: '/pricing/', current: false },
  { label: 'Changelog', href: '/changelog/', current: false },
  { label: 'Blog', href: '/blog/', current: false },
];
---

<nav class="marketing-links" aria-label="Vega site">
  {
    links.map(({ label, href, current }) => (
      <a href={href} aria-current={current ? 'page' : undefined}>
        {label}
      </a>
    ))
  }
  <a class="cta" href="/pricing/">Get started</a>
</nav>
<Default><slot /></Default>

<style>
  /* Unlayered on purpose: this footer renders inside `.sidebar-content`,
	   and starlight.css styles `.sidebar-content a` (hover pill, current-page
	   pill) with unlayered rules that would beat anything in a layer. The
	   `nav.marketing-links` prefix out-specifies those selectors so the
	   links here match the header treatment instead of the sidebar's. */

  nav.marketing-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: 1.5rem;
    row-gap: 0.75rem;
    border-top: 1px solid var(--sl-color-gray-6);
    padding-block: 1rem;
  }

  nav.marketing-links a,
  nav.marketing-links a:hover,
  nav.marketing-links a:focus {
    font-size: 0.875rem;
    line-height: 1;
    text-decoration: none;
    background: none;
    border-radius: 0;
    box-shadow: none;
    color: var(--pulsar-fg-2, var(--sl-color-gray-2));
    transition: color 150ms;
  }

  nav.marketing-links a:hover {
    color: var(--pulsar-fg, var(--sl-color-white));
  }

  nav.marketing-links a[aria-current='page'],
  nav.marketing-links a[aria-current='page']:hover,
  nav.marketing-links a[aria-current='page']:focus {
    color: var(--pulsar-fg, var(--sl-color-white));
    font-weight: 500;
    background: none;
    box-shadow: none;
  }

  nav.marketing-links a:focus-visible {
    outline: 2px solid var(--pulsar-brand, var(--sl-color-accent));
    outline-offset: 2px;
  }

  /* Mirrors Button.astro variant="primary" size="sm". */
  nav.marketing-links a.cta,
  nav.marketing-links a.cta:hover,
  nav.marketing-links a.cta:focus {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    padding-inline: 0.75rem;
    border-radius: 0.5rem;
    margin-inline-start: auto;
    font-weight: 500;
    white-space: nowrap;
    color: var(--pulsar-ink, var(--sl-color-black));
    background: linear-gradient(
      to right,
      var(--pulsar-brand, var(--sl-color-accent)),
      var(--pulsar-accent, var(--sl-color-accent-high))
    );
    transition: filter 200ms;
  }

  nav.marketing-links a.cta:hover {
    filter: brightness(1.1);
  }

  nav.marketing-links a.cta:active {
    filter: brightness(0.95);
  }
</style>
