---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Vega is the API platform for teams that ship — build, deploy, and observe APIs without the infrastructure tax.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-panel focus:px-3 focus:py-2 focus:text-sm"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      // Expressive Code marks scrollable code blocks role="region" without a
      // name; unnamed duplicate landmarks fail axe and confuse screen readers.
      for (const pre of document.querySelectorAll('pre[role="region"]:not([aria-label])')) {
        const lang = (pre as HTMLElement).dataset.language;
        pre.setAttribute('aria-label', lang ? `Code sample (${lang})` : 'Code sample');
      }
    </script>
  </body>
</html>
