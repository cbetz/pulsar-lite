---
import { getCollection, render } from 'astro:content';
import TagPill from '../components/blog/TagPill.astro';
import Container from '../components/Container.astro';
import Glow from '../components/Glow.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/expressive-code.css';

const entries = (await getCollection('changelog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

type Tag = 'breaking' | 'feature' | 'improvement' | 'fix';

const tagOrder: Tag[] = ['breaking', 'feature', 'improvement', 'fix'];

const tagStyles: Record<Tag, string> = {
  feature: 'border-accent/30 bg-accent/10 text-accent-bright',
  improvement: 'border-brand/40 bg-brand/15 text-brand-bright',
  fix: 'border-line-2 bg-panel-2 text-fg-2',
  breaking: 'border-amber-400/30 bg-amber-400/10 text-amber-300',
};

const sortTags = (tags: Tag[]) =>
  [...tags].sort((a, b) => tagOrder.indexOf(a) - tagOrder.indexOf(b));

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });

const anchor = (version: string) => `v${version.replaceAll('.', '-')}`;
---

<BaseLayout
  title="Changelog — Vega"
  description="New features, performance work, and fixes from the Vega team. Breaking changes are always flagged with a migration path."
>
  <section class="relative overflow-hidden">
    <Glow class="left-1/2 top-[-220px] h-[420px] w-[760px] -translate-x-1/2" />

    <Container class="relative py-20 sm:py-28">
      <header class="max-w-2xl">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Changelog</p>
        <h1 class="mt-3 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
          Everything we <span class="text-gradient">ship</span>, documented
        </h1>
        <p class="mt-5 max-w-xl text-pretty text-lg leading-relaxed text-fg-2">
          New features, performance work, and fixes — released every few weeks. Breaking changes
          are always flagged with a migration path.
        </p>
      </header>

      <div class="mt-16 max-w-4xl sm:mt-20">
        {
          rendered.map(({ entry, Content }, index) => (
            <article
              id={anchor(entry.data.version)}
              class="grid scroll-mt-24 gap-x-12 md:grid-cols-[10rem_1fr]"
            >
              {/* Left rail: version + date (desktop, sticky) */}
              <div class="hidden md:block">
                <div class="sticky top-24 pt-0.5">
                  <a
                    href={`#${anchor(entry.data.version)}`}
                    class="font-mono text-sm font-medium text-fg transition-colors hover:text-accent-bright focus-visible:outline-2 focus-visible:outline-brand"
                  >
                    v{entry.data.version}
                  </a>
                  <time
                    datetime={entry.data.pubDate.toISOString().slice(0, 10)}
                    class="mt-1.5 block font-mono text-[13px] text-fg-3"
                  >
                    {formatDate(entry.data.pubDate)}
                  </time>
                </div>
              </div>

              {/* Timeline rail + entry content */}
              <div
                class:list={[
                  'relative min-w-0 pl-8 sm:pl-10',
                  index === rendered.length - 1
                    ? 'border-l border-transparent pb-6 [border-image:linear-gradient(to_bottom,var(--color-line),transparent_88%)_1]'
                    : 'border-l border-line pb-16 sm:pb-20',
                ]}
              >
                {/* Dot marker; the newest release gets the lit dot */}
                <span
                  aria-hidden="true"
                  class:list={[
                    'absolute left-[0.5px] top-2 h-2.5 w-2.5 -translate-x-1/2 rounded-full',
                    index === 0
                      ? 'bg-accent shadow-[0_0_10px_rgb(34_211_238/0.7)]'
                      : 'border border-line-2 bg-panel-2',
                  ]}
                ></span>

                {/* Version + date (mobile) */}
                <div class="flex items-baseline gap-3 md:hidden">
                  <a
                    href={`#${anchor(entry.data.version)}`}
                    class="font-mono text-sm font-medium text-fg focus-visible:outline-2 focus-visible:outline-brand"
                  >
                    v{entry.data.version}
                  </a>
                  <time
                    datetime={entry.data.pubDate.toISOString().slice(0, 10)}
                    class="font-mono text-[13px] text-fg-3"
                  >
                    {formatDate(entry.data.pubDate)}
                  </time>
                </div>

                <h2 class="mt-3 text-balance text-2xl font-semibold tracking-tight text-fg md:mt-0">
                  {entry.data.title}
                </h2>

                {entry.data.tags.length > 0 && (
                  <ul class="mt-3.5 flex flex-wrap gap-2" aria-label="Release tags">
                    {sortTags(entry.data.tags as Tag[]).map((tag) => (
                      <li>
                        <TagPill class={tagStyles[tag]}>{tag}</TagPill>
                      </li>
                    ))}
                  </ul>
                )}

                <div class="changelog-prose mt-6">
                  <Content />
                </div>
              </div>
            </article>
          ))
        }

        <div class="grid gap-x-12 md:grid-cols-[10rem_1fr]">
          <div class="hidden md:block"></div>
          <p class="pl-8 text-sm text-fg-3 sm:pl-10">
            Release notes for versions before 1.4.0 are archived on <a
              href="https://github.com"
              class="text-fg-2 underline decoration-line-2 underline-offset-[3px] transition-colors hover:text-fg"
            >GitHub</a>.
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style is:global>
  /* Rendered markdown inside changelog entries. Tailwind preflight zeroes
     margins, so spacing is restored here with an owl selector. */
  .changelog-prose {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-fg-2);
  }

  .changelog-prose > * + * {
    margin-top: 1rem;
  }

  .changelog-prose strong {
    color: var(--color-fg);
    font-weight: 600;
  }

  .changelog-prose a {
    color: var(--color-fg);
    text-decoration: underline;
    text-decoration-color: var(--color-line-2);
    text-underline-offset: 3px;
    transition: text-decoration-color 150ms;
  }

  .changelog-prose a:hover {
    text-decoration-color: var(--color-accent);
  }

  .changelog-prose :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 0.8125em;
    color: var(--color-fg);
    background: rgb(255 255 255 / 0.06);
    border: 1px solid var(--color-line);
    border-radius: 0.375rem;
    padding: 0.125rem 0.375rem;
    /* Keep the pill closed (border + padding on every fragment)
       when the code wraps across lines. */
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }

  /* Fallback for raw <pre> blocks (fenced code normally renders through
     Expressive Code below, which nests its pre inside a figure). */
  .changelog-prose > pre {
    margin-block: 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: 0.75rem;
    background: rgb(255 255 255 / 0.03);
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }

  /* Fenced code renders through Expressive Code; the shared skin is
     imported from src/styles/expressive-code.css in the frontmatter.
     Only the prose rhythm lives here. */
  .changelog-prose .expressive-code {
    margin-block: 1.25rem;
  }

  .changelog-prose ul {
    list-style: disc;
    padding-left: 1.375rem;
  }

  .changelog-prose li + li {
    margin-top: 0.375rem;
  }

  .changelog-prose li::marker {
    color: var(--color-fg-3);
  }
</style>
