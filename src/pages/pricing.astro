---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Glow from '../components/Glow.astro';
import TierCards from '../components/pricing/TierCards.astro';
import ComparisonTable from '../components/pricing/ComparisonTable.astro';
import Faq from '../components/pricing/Faq.astro';
import CtaStrip from '../components/pricing/CtaStrip.astro';
---

<BaseLayout
  title="Pricing — Vega"
  description="Start free with 100k requests a month. Upgrade to Pro for 10M requests, all 28 regions, and request-level tracing — or Scale for unlimited usage, SSO, and a 99.99% SLA."
>
  <section class="relative overflow-hidden">
    <Glow class="left-1/2 top-[-160px] h-[420px] w-[760px] -translate-x-1/2" />
    <Container class="relative pb-20 pt-16 sm:pb-24 sm:pt-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="font-mono text-[13px] uppercase tracking-widest text-fg-3">Pricing</p>
        <h1 class="mt-4 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
          Pricing that <span class="text-gradient">scales with you</span>
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-pretty text-lg leading-relaxed text-fg-2">
          Every plan runs the same platform — edge caching, single-command deploys, structured
          logs. Pay for more traffic, more regions, and stronger guarantees as you grow.
        </p>
      </div>

      <div class="mt-14 sm:mt-16">
        <TierCards />
      </div>

      <p class="mt-8 text-center text-[13px] text-fg-2">
        All prices in USD. Pro and Scale are 20% cheaper when billed annually.
      </p>
    </Container>
  </section>

  <ComparisonTable />
  <Faq />
  <CtaStrip />
</BaseLayout>
